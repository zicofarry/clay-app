# Clay Gateway — Environment Variables
# Copy to .env for local development (never commit .env)

# Required
JWT_SECRET=your-super-secret-key-min-32-chars

# Optional (defaults shown)
PORT=8080
JWT_ISSUER=clay-auth-service
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
ROUTES_FILE=config/routes.yaml
CORS_ORIGINS=*

# Timeouts (Go duration format or plain seconds)
READ_TIMEOUT=10s
WRITE_TIMEOUT=30s
IDLE_TIMEOUT=60s
